<Window x:Class="Sportly.Registration.RegistrationWin"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Sportly.Registration"
        mc:Ignorable="d"
        Title="RegistrationWin" Height="450" Width="800">
    <Grid>
        <TextBlock HorizontalAlignment="Left" Margin="105,30" TextWrapping="Wrap" Text="Meno" VerticalAlignment="Top" Height="40" Width="130" LineHeight="9" FontSize="20" FontWeight="Bold"/>
        <TextBox x:Name="_firstName" HorizontalAlignment="Left" Margin="462,30,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="120" Height="20" FontSize="18" TextChanged="TextBox_TextChanged" BorderBrush="#FF727377"/>
        <TextBlock HorizontalAlignment="Left" Margin="105,70" TextWrapping="Wrap" Text="Priezvisko" VerticalAlignment="Top" Height="40" Width="100" LineHeight="9" FontSize="20" FontWeight="Bold" RenderTransformOrigin="0.48,1.506"/>
        <TextBox x:Name="_lastName" HorizontalAlignment="Left" Margin="462,70,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="120" Height="20" FontSize="18" TextChanged="TextBox_TextChanged" BorderBrush="#FF727377"/>
        <TextBlock HorizontalAlignment="Left" Margin="105,110,0,0" TextWrapping="Wrap" Text="Dátum narodenia" VerticalAlignment="Top" Height="35" Width="172" LineHeight="9" FontSize="20" FontWeight="Bold"/>
        <DatePicker x:Name="_birthDate" HorizontalAlignment="Left" Margin="462,110,0,0" VerticalAlignment="Top" Width="120" Height="20">
            <DatePicker.BorderBrush>
                <LinearGradientBrush EndPoint="0.5,0" StartPoint="0.5,1">
                    <GradientStop Color="#FFA3AEB9"/>
                    <GradientStop Color="#FF8399A9" Offset="0.375"/>
                    <GradientStop Color="#FF718597" Offset="0.375"/>
                    <GradientStop Color="#FF727377" Offset="1"/>
                </LinearGradientBrush>
            </DatePicker.BorderBrush>
        </DatePicker>
        <TextBlock HorizontalAlignment="Left" Margin="105,150" TextWrapping="Wrap" Text="Adresa" VerticalAlignment="Top" Height="40" Width="100" LineHeight="9" FontSize="20" FontWeight="Bold"/>
        <TextBox x:Name="_address" HorizontalAlignment="Left" Margin="462,150,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="120" Height="20" FontSize="18" TextChanged="TextBox_TextChanged" BorderBrush="#FF727377"/>
        <TextBlock HorizontalAlignment="Left" Margin="105,190,0,0" TextWrapping="Wrap" Text="E-mail" VerticalAlignment="Top" Height="40" Width="100" LineHeight="9" FontSize="20" FontWeight="Bold"/>
        <TextBox x:Name="_email" HorizontalAlignment="Left" Margin="462,190,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="120" Height="20" FontSize="18" TextChanged="TextBox_TextChanged" BorderBrush="#FF727377"/>
        <TextBlock HorizontalAlignment="Left" Margin="105,230,0,0" TextWrapping="Wrap" Text="Telefon" VerticalAlignment="Top" Height="40" Width="100" LineHeight="9" FontSize="20" FontWeight="Bold"/>
        <TextBox x:Name="_phoneNumber" HorizontalAlignment="Left" Margin="462,230,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="120" Height="20" FontSize="18" TextChanged="TextBox_TextChanged" BorderBrush="#FF727377"/>
        <TextBlock HorizontalAlignment="Left" Margin="105,270,0,0" TextWrapping="Wrap" Text="Pohlavie" VerticalAlignment="Top" Height="40" Width="100" LineHeight="9" FontSize="20" FontWeight="Bold" RenderTransformOrigin="0.587,1.657"/>
        <ComboBox x:Name="genderSelect" HorizontalAlignment="Left" Margin="462,279,0,0" VerticalAlignment="Top" Width="120"                                                                                                             />
        <Button Content="Vytvorit konto" HorizontalAlignment="Left" Margin="462,380,0,0" VerticalAlignment="Top" RenderTransformOrigin="-0.231,-0.912" Width="120" Height="25" Click="Button_Click"/>
        <TextBlock HorizontalAlignment="Left" Margin="105,310,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Height="40" Width="100" LineHeight="9" FontSize="20" FontWeight="Bold" RenderTransformOrigin="0.587,1.657"><Run Text="Heslo"/><LineBreak/><Run/></TextBlock>
        <TextBox x:Name="_password" HorizontalAlignment="Left" Margin="462,317,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="120" Height="20" FontSize="18" TextChanged="TextBox_TextChanged" BorderBrush="#FF727377"/>

    </Grid>
</Window>
