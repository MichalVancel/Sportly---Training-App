<Window x:Class="Sportly.Dash.AddEvent"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Sportly.Dash"
        mc:Ignorable="d"
        Background="Black"
        Title="AddEvent" Height="550" Width="500">

    <StackPanel>
        <Label Content="Pridať Udalosť" FontSize="24" FontFamily="Artifakt Element Heavy" HorizontalAlignment="Center" Margin="0,20,0,20" Foreground="#B22222"/>

        <Border BorderBrush="#333333" BorderThickness="1" Background="#1E1E1E" CornerRadius="25" Margin="10,0,10,10" Height="330">
            <Canvas>
                <Label Content="Miesto" Margin="105,30,0,0" Foreground="White" Height="30" Width="67" FontSize="17" FontFamily="Artifakt Element Heavy"/>
                <TextBox Margin="235,32,0,0" Width="160" Height="28" Background="#2D2D2D" Foreground="White" FontSize="16"/>

                <Label Content="Dátum" Margin="105,75,0,0" Foreground="White" Height="30" Width="67" FontSize="17" FontFamily="Artifakt Element Heavy"/>
                <DatePicker Margin="235,80,0,0" Width="160"/>

                <Label Content="Čas" Margin="105,135,0,0" Foreground="White" Height="31" Width="46" FontSize="17" FontFamily="Artifakt Element Heavy"/>
                <Label Content="Od" Margin="191,121,0,0" Foreground="White" Height="31" Width="36" FontSize="17" FontFamily="Artifakt Element Heavy"/>
                <TextBox x:Name="TimeFrom" Margin="235,124,0,0" Width="160" Height="28" Background="#2D2D2D" Foreground="White" FontSize="16"/>

                <Label Content="Do" Margin="191,152,0,0" Foreground="White" Height="31" Width="36" FontSize="17" FontFamily="Artifakt Element Heavy"/>
                <TextBox x:Name="TimeTo" Margin="235,155,0,0" Width="160" Height="28" Background="#2D2D2D" Foreground="White" FontSize="16"/>

                <Label Content="Kategória" Margin="105,210,0,0" Foreground="White" Height="33" Width="92" FontSize="17" FontFamily="Artifakt Element Heavy"/>
                <ComboBox x:Name="EventKategory" Margin="235,212,0,0" Width="160" Height="28" Background="#2D2D2D" Foreground="White" FontSize="16">
                    <ComboBoxItem Content="Muži" Background="#2D2D2D" Foreground="White"/>
                    <ComboBoxItem Content="Juniory" Background="#2D2D2D" Foreground="White"/>
                    <ComboBoxItem Content="Dorastenci" Background="#2D2D2D" Foreground="White"/>
                    <ComboBoxItem Content="Starší žiaci" Background="#2D2D2D" Foreground="White"/>
                    <ComboBoxItem Content="Mladší žiaci" Background="#2D2D2D" Foreground="White"/>
                </ComboBox>

                <Label Content="Typ" Margin="105,255,0,0" Foreground="White" Height="31" Width="46" FontSize="17" FontFamily="Artifakt Element Heavy"/>
                <ComboBox x:Name="EventType" Margin="235,257,0,0" Width="160" Background="#2D2D2D" Foreground="White" FontSize="16" Height="28">
                    <ComboBoxItem Content="Tréning" Background="#2D2D2D" Foreground="White"/>
                    <ComboBoxItem Content="Zápas" Background="#2D2D2D" Foreground="White"/>
                </ComboBox>
            </Canvas>
        </Border>

        <Border Background="#B22222" CornerRadius="12" Width="180" Height="45" Margin="0,15,0,0" HorizontalAlignment="Center">
            <Button Content="Vytvoriť Udalosť" Background="Transparent" Foreground="White" FontFamily="Artifakt Element Heavy" FontSize="14" BorderBrush="Transparent"/>
        </Border>

    </StackPanel>
</Window>