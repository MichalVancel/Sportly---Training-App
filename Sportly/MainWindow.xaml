<Window x:Class="Sportly.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Sportly"
        mc:Ignorable="d"
        Title="LoginWindow" Height="450" Width="800"
        Background="#EFEBE9">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="80"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Label Content="LOGIN" 
           Grid.Row="0"
           HorizontalAlignment="Center" 
           VerticalAlignment="Center" 
           FontFamily="Artifakt Element Heavy" 
           FontSize="40"/>

        <StackPanel Grid.Row="1" 
                VerticalAlignment="Center" 
                HorizontalAlignment="Center" 
                Width="600">
            <Grid Margin="0,10">
                <Label Content="EMAIL" 
                   HorizontalAlignment="Left" 
                   FontFamily="Artifakt Element Heavy" 
                   FontSize="25"/>
                <TextBox 
                    x:Name="Email"
                    HorizontalAlignment="Right" 
                     Width="300" 
                     Height="35" 
                     VerticalAlignment="Center"
                     FontSize="25"/>
            </Grid>

            <Grid Margin="0,10">
                <Label Content="PASSWORD" 
                   HorizontalAlignment="Left" 
                   FontFamily="Artifakt Element Heavy" 
                   FontSize="25"/>
                <PasswordBox HorizontalAlignment="Right" 
                         Width="300" 
                         Height="35" 
                         VerticalAlignment="Center"
                         FontSize="25"
                         x:Name="PassWord"/>
            </Grid>
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Top">
            <Button x:Name="CreAccButt" Content="Create Account" Height="34" Width="235" FontSize="20" FontFamily="Artifakt Element Black" Background="Transparent" Margin="100,0" Click="CreAccButt_Click" />
            <Button x:Name="LoginButton" Content="Login" Height="34" Width="235" FontSize="20" FontFamily="Artifakt Element Black" Background="Transparent" Margin="100,0" Click="LoginButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
