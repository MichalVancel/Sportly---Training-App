<Window x:Class="Sportly.AfterLogin.TeamCreateWin"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Sportly.AfterLogin"
        mc:Ignorable="d"
        Title="TeamCreateWin" Height="600" Width="1000"
        Background="Black">
    <Grid Background="#121212">
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">

            <Grid Width="700" Margin="0,0,0,30">
                <Border Background="#B22222"  Height="60" Width="60" HorizontalAlignment="Left"  CornerRadius="30" Margin="-123,10,0,10">

                    <Button Content="←"  HorizontalAlignment="Center" VerticalAlignment="Center" Height="60" Width="60" FontSize="70" Padding="0,-25,0,0"  HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Background="Transparent" Foreground="White"  Click="BackButton_Click"  BorderBrush="Transparent"/>

                </Border>

                <Label Content="VYTVORIŤ TÍM"  HorizontalAlignment="Center" FontSize="50" FontFamily="Artifakt Element Heavy"  Foreground="#B22222" VerticalAlignment="Center"/>

            </Grid>

            <Border Background="#1E1E1E"  CornerRadius="25"  Padding="50,60" BorderBrush="#333333"  BorderThickness="2" MinWidth="700">

                <StackPanel>
                    <Grid Margin="0,0,0,25">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="200"/>
                            <ColumnDefinition Width="300"/>
                        </Grid.ColumnDefinitions>
                        <Label Content="Názov tímu" FontSize="26" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                        <TextBox x:Name="TeamName" Grid.Column="1" Height="45" FontSize="20" Background="#2D2D2D" Foreground="White" BorderBrush="#555" VerticalContentAlignment="Center" Padding="8,0"/>
                    </Grid>

                    <Grid Margin="0,0,0,25">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="200"/>
                            <ColumnDefinition Width="300"/>
                        </Grid.ColumnDefinitions>
                        <Label Content="Mesto" FontSize="26" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                        <TextBox x:Name="CityName" Grid.Column="1" Height="45" FontSize="20" Background="#2D2D2D" Foreground="White" BorderBrush="#555" VerticalContentAlignment="Center" Padding="8,0"/>
                    </Grid>

                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="200"/>
                            <ColumnDefinition Width="300"/>
                        </Grid.ColumnDefinitions>
                        <Label Content="Šport" FontSize="26" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                        <ComboBox x:Name="Sport" Grid.Column="1" Height="45" FontSize="20" VerticalContentAlignment="Center">
                            <ComboBoxItem Content="Florbal" Background="#2D2D2D" Foreground="White"/>
                            <ComboBoxItem Content="Futbal" Background="#2D2D2D" Foreground="White"/>
                            <ComboBoxItem Content="Basketbal" Background="#2D2D2D" Foreground="White"/>
                            <ComboBoxItem Content="Hokej" Background="#2D2D2D" Foreground="White"/>
                            <ComboBoxItem Content="Volejbal" Background="#2D2D2D" Foreground="White"/>
                            <ComboBoxItem Content="Tenis" Background="#2D2D2D" Foreground="White"/>
                        </ComboBox>
                    </Grid>
                </StackPanel>
            </Border>

            <Border Background="#B22222" Height="65" Width="280"  CornerRadius="20"  Margin="0,40,0,0"  HorizontalAlignment="Center">

                <Button Content="Vytvoriť tím"  Background="Transparent"  BorderBrush="Transparent"  Foreground="White" FontSize="24"  FontWeight="Bold"  Click="Button_Click"/>

            </Border>

        </StackPanel>
    </Grid>
</Window>
